# ── Snowflake credentials ─────────────────────────────────────
# Real connection file with account/user — only the .example.toml is tracked.
config/connection.toml
# Private keys for key-pair auth.
*.pem
# Any local environment-variable file holding secrets.
.env
# Any SQL script filled in with a real secret/PAT value, never committed.
*.local.sql

# ── Internal operational docs ─────────────────────────────────
# Account-specific debugging narratives, not for the public repo.
docs/troubleshooting/
# Ad hoc SHOW/SELECT diagnostic output, not real lab/project content.
**/schema-check.csv
# Local unzip of dynamic-tables.zip (already tracked) — temporary extraction for CoCo skill upload.
labs/coco-foundations/assets/dynamic-tables/
# Snowsight's default export filenames for ad hoc worksheet results — these
# have carried real account/user PII (email, login name) during debugging.
**/Untitled*.csv
**/scratchpad*.csv
**/Autograder_Result*.csv
# Project-level Claude instructions are private working notes, never public.
CLAUDE.md

# ── Python ────────────────────────────────────────────────────
# Compiled bytecode cache.
__pycache__/
# Compiled Python files.
*.pyc
# Local virtual environment.
.venv/
# Alternate virtual environment name.
venv/

# ── Eval run output ───────────────────────────────────────────
# Generated eval run artifacts, not source-controlled.
eval/results/*.json
# Keep the directory itself tracked.
!eval/results/.gitkeep

# ── OS / editor ───────────────────────────────────────────────
# macOS Finder metadata.
.DS_Store
# Windows Explorer thumbnail cache.
Thumbs.db
# Editor-local settings.
.vscode/
.idea/
